{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Beckn AI Agent Service Schema",
  "description": "Domain-specific schema for AI agent services on the Beckn network.",
  "version": "0.1.0",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "@context": {
      "type": "string"
    },
    "@type": {
      "type": "string"
    },
    "capabilities": {
      "type": "array",
      "items": { "type": "string" }
    },
    "languages": {
      "type": "array",
      "items": { "type": "string" }
    },
    "inputSchema": {
      "type": "object",
      "properties": {
        "accepts": { "type": "array", "items": { "type": "string" } },
        "maxSize": { "type": "string" }
      }
    },
    "outputSchema": {
      "type": "object",
      "properties": {
        "returns": { "type": "string" }
      }
    },
    "pricing": {
      "type": "object",
      "properties": {
        "model": { "type": "string" },
        "currency": { "type": "string" },
        "unitPrice": { "type": "number" }
      }
    },
    "sla": {
      "type": "object",
      "properties": {
        "maxLatency": { "type": "string" },
        "accuracy": { "type": "number" },
        "uptime": { "type": "number" }
      }
    },
    "dataResidency": { "type": "string" },
    "startedAt": { "type": "string", "format": "date-time" },
    "completedAt": { "type": "string", "format": "date-time" },
    "latencyMs": { "type": "integer" },
    "tokensUsed": {
      "type": "object",
      "properties": {
        "input":  { "type": "integer" },
        "output": { "type": "integer" },
        "total":  { "type": "integer" }
      }
    },
    "model": { "type": "string", "description": "LLM model name used for execution" },
    "result": { "type": "object" },
    "status": {
      "type": "string",
      "enum": ["PENDING", "RUNNING", "COMPLETED", "FAILED"]
    }
  },
  "required": ["@context", "@type"]
}
