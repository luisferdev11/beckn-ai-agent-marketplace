{
  "info": {
    "name": "AI Marketplace — BPP (Provider Portal)",
    "description": "Provider workflow: register your company, add agents, then publish to the Beckn network.\n\nFlow: category → provider → agent → publish\n\nTarget: bpp-api at http://localhost:3002\n\nAll IDs are SERIAL integers (auto-generated by PostgreSQL).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1 — Setup (Category + Provider)",
      "item": [
        {
          "name": "create category",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201', function () { pm.response.to.have.status(201); });",
                  "pm.test('Category created', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.category_id).to.be.a('number');",
                  "    pm.collectionVariables.set('category_id', json.category_id);",
                  "    console.log('Category ID saved: ' + json.category_id);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{category_name}}\",\n  \"display_name\": { \"en\": \"{{category_display_en}}\", \"es\": \"{{category_display_es}}\" },\n  \"description\": \"{{category_description}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{bpp_api_url}}/api/categories",
              "host": ["{{bpp_api_url}}"],
              "path": ["api", "categories"]
            },
            "description": "Create a category. Uses ON CONFLICT so it's safe to run multiple times."
          },
          "response": []
        },
        {
          "name": "create provider",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201', function () { pm.response.to.have.status(201); });",
                  "pm.test('Provider created', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.provider.id).to.be.a('number');",
                  "    pm.collectionVariables.set('provider_id', json.provider.id);",
                  "    console.log('Provider ID saved: ' + json.provider.id);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"subscriber_id\": \"{{provider_subscriber_id}}\",\n  \"bpp_uri\": \"{{provider_bpp_uri}}\",\n  \"public_key\": \"{{provider_public_key}}\",\n  \"organization_details\": {\n    \"name\": \"{{provider_org_name}}\",\n    \"contact_email\": \"{{provider_contact_email}}\"\n  }\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{bpp_api_url}}/api/providers",
              "host": ["{{bpp_api_url}}"],
              "path": ["api", "providers"]
            },
            "description": "Register your company as a provider. The response includes provider_id (integer) which is auto-saved."
          },
          "response": []
        },
        {
          "name": "list categories",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "const cats = pm.response.json();",
                  "console.log('Total categories: ' + cats.length);",
                  "cats.forEach(c => console.log('  id=' + c.id + ' | ' + c.name));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{bpp_api_url}}/api/categories",
              "host": ["{{bpp_api_url}}"],
              "path": ["api", "categories"]
            }
          },
          "response": []
        },
        {
          "name": "list providers",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "const provs = pm.response.json();",
                  "console.log('Total providers: ' + provs.length);",
                  "provs.forEach(p => console.log('  id=' + p.id + ' | ' + p.subscriber_id));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{bpp_api_url}}/api/providers",
              "host": ["{{bpp_api_url}}"],
              "path": ["api", "providers"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "2 — Register Agent",
      "item": [
        {
          "name": "create agent",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201', function () { pm.response.to.have.status(201); });",
                  "pm.test('Agent created', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.agent_id).to.be.a('number');",
                  "    pm.collectionVariables.set('agent_id', json.agent_id);",
                  "    console.log('Agent ID saved: ' + json.agent_id);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"provider_id\": {{provider_id}},\n  \"category_id\": {{category_id}},\n  \"agent_name\": { \"en\": \"{{agent_name}}\" },\n  \"description\": \"{{agent_description}}\",\n  \"access_point_url\": \"{{agent_endpoint}}\",\n  \"interaction_type\": \"{{agent_interaction_type}}\",\n  \"version\": \"{{agent_version}}\",\n  \"capabilities\": {{agent_capabilities}},\n  \"skills\": {{agent_skills}},\n  \"input_schema\": {{agent_input_schema}},\n  \"output_schema\": {{agent_output_schema}},\n  \"pricing_model\": { \"type\": \"{{pricing_type}}\", \"value\": {{pricing_value}}, \"currency\": \"{{pricing_currency}}\" },\n  \"sla\": { \"maxLatencyMs\": {{sla_max_latency}}, \"accuracy\": {{sla_accuracy}}, \"uptime\": {{sla_uptime}} },\n  \"jurisdiction\": \"{{agent_jurisdiction}}\",\n  \"modalities\": {{agent_modalities}},\n  \"authentication\": { \"methods\": [\"jwt\"] }\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{bpp_api_url}}/api/agents",
              "host": ["{{bpp_api_url}}"],
              "path": ["api", "agents"]
            },
            "description": "Register an AI agent. Requires provider_id and category_id (integers from previous steps)."
          },
          "response": []
        },
        {
          "name": "update agent",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "console.log('Agent updated: id=' + pm.response.json().id);"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pricing_model\": { \"type\": \"per_request\", \"value\": 0.10, \"currency\": \"USD\" },\n  \"version\": \"1.1.0\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{bpp_api_url}}/api/agents/{{agent_id}}",
              "host": ["{{bpp_api_url}}"],
              "path": ["api", "agents", "{{agent_id}}"]
            },
            "description": "Update specific fields of an agent. Only send the fields you want to change."
          },
          "response": []
        },
        {
          "name": "get agent by id",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "const a = pm.response.json();",
                  "console.log('Agent: id=' + a.id + ' status=' + a.status);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{bpp_api_url}}/api/agents/{{agent_id}}",
              "host": ["{{bpp_api_url}}"],
              "path": ["api", "agents", "{{agent_id}}"]
            }
          },
          "response": []
        },
        {
          "name": "deactivate agent",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Agent deactivated', function () {",
                  "    pm.expect(pm.response.json().message).to.eql('Agent deactivated');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{bpp_api_url}}/api/agents/{{agent_id}}",
              "host": ["{{bpp_api_url}}"],
              "path": ["api", "agents", "{{agent_id}}"]
            },
            "description": "Deactivates an agent (sets status=inactive). Does not delete data."
          },
          "response": []
        },
        {
          "name": "list agents",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "const agents = pm.response.json();",
                  "console.log('Total agents: ' + agents.length);",
                  "agents.forEach(a => console.log('  id=' + a.id + ' | ' + a.status + ' | ' + (typeof a.agent_name === 'string' ? JSON.parse(a.agent_name).en : a.agent_name.en)));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{bpp_api_url}}/api/agents",
              "host": ["{{bpp_api_url}}"],
              "path": ["api", "agents"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "3 — Publish to Network",
      "item": [
        {
          "name": "publish catalog to Fabric",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Catalog published', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.fabric.agentsInCatalog).to.be.above(0);",
                  "    console.log('Published ' + json.fabric.agentsInCatalog + ' agents to Fabric');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{bpp_api_url}}/api/publish",
              "host": ["{{bpp_api_url}}"],
              "path": ["api", "publish"]
            },
            "description": "Publishes ALL active agents from the database to Fabric Catalog Service.\n\nNo body needed — reads directly from the database."
          },
          "response": []
        }
      ]
    },
    {
      "name": "4 — Debug",
      "item": [
        {
          "name": "health check",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('DB connected', function () {",
                  "    pm.expect(pm.response.json().database).to.eql('connected');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{bpp_api_url}}/api/health",
              "host": ["{{bpp_api_url}}"],
              "path": ["api", "health"]
            }
          },
          "response": []
        },
        {
          "name": "list transactions",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "const txns = pm.response.json();",
                  "console.log('Total transactions: ' + txns.length);",
                  "txns.forEach(t => console.log('  id=' + t.id + ' | ' + t.status + ' | txn=' + t.transaction_id.substring(0,8)));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{bpp_api_url}}/api/transactions",
              "host": ["{{bpp_api_url}}"],
              "path": ["api", "transactions"]
            }
          },
          "response": []
        }
      ]
    }
  ],
  "variable": [
    { "key": "bpp_api_url", "value": "http://localhost:3002", "description": "BPP API base URL" },
    { "key": "category_name", "value": "AI-SUMMARIZATION", "description": "Category unique name" },
    { "key": "category_display_en", "value": "Document Summarizer", "description": "Category display name (English)" },
    { "key": "category_display_es", "value": "Resumen de Documentos", "description": "Category display name (Spanish)" },
    { "key": "category_description", "value": "AI-powered document summarization", "description": "Category description" },
    { "key": "category_id", "value": "", "description": "Auto-filled after creating category" },
    { "key": "provider_subscriber_id", "value": "my-company.beckn", "description": "Your Beckn subscriber ID" },
    { "key": "provider_bpp_uri", "value": "https://api.my-company.com", "description": "Your API base URL" },
    { "key": "provider_public_key", "value": "ed25519_pub_key_placeholder", "description": "Your Ed25519 public key" },
    { "key": "provider_org_name", "value": "My AI Company", "description": "Organization name" },
    { "key": "provider_contact_email", "value": "admin@my-company.com", "description": "Contact email" },
    { "key": "provider_id", "value": "", "description": "Auto-filled after creating provider" },
    { "key": "agent_name", "value": "DocSummarizer Pro", "description": "Agent display name" },
    { "key": "agent_description", "value": "AI-powered document summarization agent for legal and regulatory documents", "description": "Agent description" },
    { "key": "agent_endpoint", "value": "http://agents:3004", "description": "Agent API endpoint" },
    { "key": "agent_interaction_type", "value": "sync", "description": "sync | async | streaming" },
    { "key": "agent_version", "value": "1.0.0", "description": "Semantic version" },
    { "key": "agent_capabilities", "value": "[\"summarization\", \"bullet-points\", \"legal-analysis\"]", "description": "JSON array of capabilities" },
    { "key": "agent_skills", "value": "[{\"id\": \"document_summary\", \"description\": \"Summarizes legal documents\", \"inputModes\": [\"text/plain\", \"application/pdf\"], \"outputModes\": [\"application/json\"], \"supportedLanguages\": [\"en\", \"es\"], \"latencyBudgetMs\": 5000, \"maxTokens\": 4096}, {\"id\": \"legal_analysis\", \"description\": \"Analyzes legal clauses\", \"inputModes\": [\"text/plain\"], \"outputModes\": [\"application/json\"], \"supportedLanguages\": [\"en\"]}]", "description": "JSON array of AgentFacts skills" },
    { "key": "agent_input_schema", "value": "{ \"type\": \"object\", \"properties\": { \"text\": { \"type\": \"string\" } } }", "description": "JSON Schema for input" },
    { "key": "agent_output_schema", "value": "{ \"type\": \"object\", \"properties\": { \"result\": { \"type\": \"string\" } } }", "description": "JSON Schema for output" },
    { "key": "pricing_type", "value": "per_request", "description": "Pricing model type" },
    { "key": "pricing_value", "value": "0.05", "description": "Price per request" },
    { "key": "pricing_currency", "value": "USD", "description": "Currency code" },
    { "key": "sla_max_latency", "value": "5000", "description": "Max latency in ms" },
    { "key": "sla_accuracy", "value": "0.95", "description": "Accuracy 0.0-1.0" },
    { "key": "sla_uptime", "value": "0.995", "description": "Uptime 0.0-1.0" },
    { "key": "agent_jurisdiction", "value": "US", "description": "Country code" },
    { "key": "agent_modalities", "value": "[\"text\"]", "description": "JSON array of modalities" },
    { "key": "agent_id", "value": "", "description": "Auto-filled after creating agent" }
  ]
}
